# flick-landing — static marketing site (myflick.app root).
# Multi-stage so it builds straight from the repo (incl. a git-URL context),
# which is what the box's auto-updater uses.
#
#   podman build -t flick-landing -f deploy/Containerfile .
#   podman build -t flick-landing https://github.com/one-more-refactor/flick-landing.git -f deploy/Containerfile

FROM docker.io/oven/bun:1 AS build
WORKDIR /app
COPY package.json bun.lock ./
RUN bun install --frozen-lockfile || bun install
COPY . .
RUN bun run build

FROM docker.io/library/nginx:alpine
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html/
EXPOSE 80
