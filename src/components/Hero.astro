---
// The headline moment: the product pitching itself at 700 wpm. Everything in
// here is choreographed by SiteMotion on load; the .hv veils and .h1-mask
// lines only hide when the motion controller claims the page.
import HeroReader from './HeroReader.astro';
import { AUTH_DEMO_WORDS } from '../lib/demos';
import { APP_URL } from '../config';
---

<section class="hero">
  <div class="wrap">
    <p class="eyebrow hv">read it in a <b>flick</b></p>
    <div class="stage">
      <HeroReader words={AUTH_DEMO_WORDS} wpm={700} meter wait />
    </div>
    <h1 class="h1">
      <span class="h1-mask"><span class="h1-line">Read 2–3× faster,</span></span>
      <span class="h1-mask"><span class="h1-line">one word at a time.</span></span>
    </h1>
    <p class="sub hv">
      flick plays your reading one word at a time, each word anchored on its pivot letter — so
      your eyes stop crawling across lines and the text comes to you. Open source,
      self-hostable, free to read.
    </p>
    <div class="cta-row hv">
      <a class="btn" href={APP_URL}>Start reading <span class="ar">→</span></a>
      <a class="btn-ghost" href="#how">how it works</a>
    </div>
    <a class="cue hv" href="#how" aria-label="Scroll to how it works">
      <span class="cue-t">how it works</span>
      <span class="cue-g">↓</span>
    </a>
  </div>
</section>

<style>
  .hero {
    padding: clamp(52px, 9vh, 110px) 0 clamp(30px, 5vh, 56px);
    text-align: center;
  }
  .eyebrow {
    font-size: 12px;
    letter-spacing: 0.05em;
    color: var(--dim);
    margin: 0 0 clamp(28px, 6vh, 52px);
  }
  .eyebrow b { color: var(--ink); }
  .stage { max-width: 720px; margin: 0 auto clamp(36px, 6vh, 60px); }
  .h1 {
    font-size: clamp(28px, 5vw, 46px);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -0.01em;
    margin: 0 0 20px;
  }
  .h1-mask { display: block; overflow: hidden; }
  .h1-line { display: block; }
  .sub {
    max-width: 60ch;
    margin: 0 auto 30px;
    color: var(--dim);
    font-size: 14px;
    line-height: 1.7;
  }
  .cta-row {
    display: flex;
    gap: 16px;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }
  .cue {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    margin-top: clamp(30px, 6vh, 56px);
    color: var(--dim);
    transition: color var(--t-std) var(--ease);
  }
  .cue:hover { color: var(--ink); }
  .cue-t { font-size: 10px; letter-spacing: 0.26em; text-transform: uppercase; }
  .cue-g { display: block; font-size: 14px; color: var(--accent); }
</style>
