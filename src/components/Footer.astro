---
// Footer: the mark, the open-source doors, and the six looks — live accent
// swatches that switch data-theme (shared with the app via flick.theme).
import { APP_URL, REPO } from '../config';

const THEMES = [
  { name: 'paper', hex: '#d8342b' },
  { name: 'signal', hex: '#e5231b' },
  { name: 'sage', hex: '#3e8a00' },
  { name: 'tide', hex: '#0071b8' },
  { name: 'dusk', hex: '#7a3dd4' },
  { name: 'noir', hex: 'var(--ink)' },
];
---

<footer class="foot">
  <div class="wrap grid">
    <div class="brand">
      <span class="mark">FLICK<span class="cur">_</span></span>
      <span class="tag">read it in a flick</span>
    </div>
    <nav class="links" aria-label="Footer">
      <a href={REPO} target="_blank" rel="noopener">GitHub ↗</a>
      <a href={REPO} target="_blank" rel="noopener">Self-host ↗</a>
      <a href={REPO} target="_blank" rel="noopener">AGPL-3.0</a>
      <a href="/impressum/">Impressum</a>
      <a href="/datenschutz/">Datenschutz</a>
      <a href={APP_URL}>Open flick →</a>
    </nav>
    <div class="themes">
      <span class="lab">six looks</span>
      <div class="dots">
        {THEMES.map((t) => (
          <button
            class="dot"
            data-set-theme={t.name}
            style={`--sw:${t.hex}`}
            aria-label={`Switch to the ${t.name} theme`}
            title={t.name}
          ></button>
        ))}
      </div>
    </div>
  </div>
  <div class="wrap base">
    <span>© 2026 flick — made in the open</span>
  </div>
</footer>

<style>
  .foot { border-top: 1px solid var(--line); padding: 34px 0 26px; background: var(--bg); transition: background var(--t-flick) var(--ease); }
  .grid {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 22px;
    flex-wrap: wrap;
  }
  .brand { display: flex; flex-direction: column; gap: 4px; }
  .mark { font-size: 13px; font-weight: 700; letter-spacing: 0.22em; }
  .cur { color: var(--accent); }
  .tag { font-size: 11px; color: var(--dim); }

  .links { display: flex; gap: 20px; flex-wrap: wrap; }
  .links a {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--dim);
    transition: color var(--t-std) var(--ease);
  }
  .links a:hover { color: var(--ink); }

  .themes { display: flex; align-items: center; gap: 12px; }
  .lab {
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--dim);
  }
  .dots { display: flex; gap: 6px; }
  .dot {
    width: 14px;
    height: 14px;
    padding: 0;
    background: var(--sw);
    border: 1px solid var(--line);
    transition: transform var(--t-micro) var(--ease);
  }
  .dot:hover { transform: scale(1.25); }

  .base {
    margin-top: 24px;
    padding-top: 18px;
    border-top: 1px solid var(--line);
    font-size: 11px;
    color: var(--dim);
    letter-spacing: 0.06em;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-set-theme]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const theme = btn.getAttribute('data-set-theme');
      if (!theme) return;
      document.documentElement.setAttribute('data-theme', theme);
      try {
        localStorage.setItem('flick.theme', theme);
      } catch {
        /* private mode */
      }
    });
  });
</script>
