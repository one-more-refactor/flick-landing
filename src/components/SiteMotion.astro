---
// The site-wide motion controller. One lazy boot behind the reduced-motion
// gate: GSAP drives the hero load choreography + every scroll reveal + the
// pinned ORP alignment scene, Lenis smooths the scroll on GSAP's ticker, and
// anime.js v4 handles the micro-layer (count-ups, staggers, hover flourishes).
// Without JS or with prefers-reduced-motion the page is complete and static —
// html[data-motion] is only set once this controller claims it, and removed
// again if the lazy chunks fail, so nothing can stay hidden.
---

<script>
  const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
  const root = document.documentElement;

  if (!mq.matches) {
    root.setAttribute('data-motion', 'on');
    boot().catch(() => root.removeAttribute('data-motion'));
  }

  async function boot() {
    const [{ gsap }, { ScrollTrigger }, { default: Lenis }, { animate, stagger }] =
      await Promise.all([
        import('gsap'),
        import('gsap/ScrollTrigger'),
        import('lenis'),
        import('animejs'),
      ]);

    gsap.registerPlugin(ScrollTrigger);

    /* ---------- lenis on gsap's ticker ---------- */
    const lenis = new Lenis({ anchors: { offset: -72 } });
    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add((time) => lenis.raf(time * 1000));
    gsap.ticker.lagSmoothing(0);

    /* ---------- hero load choreography ---------- */
    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
    tl.fromTo('[data-nav]', { y: -14, opacity: 0 }, { y: 0, opacity: 1, duration: 0.55 })
      .fromTo('.hero .eyebrow', { opacity: 0 }, { opacity: 1, duration: 0.45 }, '-=0.25')
      .fromTo(
        '.hero .hr-rail',
        { scaleX: 0, opacity: 0 },
        { scaleX: 1, opacity: 1, duration: 0.7, stagger: 0.09, ease: 'power2.inOut' },
        '-=0.15'
      )
      .fromTo('.hero .hr-word', { opacity: 0 }, { opacity: 1, duration: 0.35 }, '-=0.3')
      .fromTo('.hero .hr-prog, .hero .hr-meter', { opacity: 0 }, { opacity: 1, duration: 0.35 }, '<')
      .add(() => window.dispatchEvent(new Event('flick:hero-go')))
      .fromTo(
        '.hero .h1-line',
        { yPercent: 115 },
        { yPercent: 0, duration: 0.85, stagger: 0.12, ease: 'power4.out' },
        '-=0.05'
      )
      .fromTo('.hero .sub', { opacity: 0, y: 14 }, { opacity: 1, y: 0, duration: 0.6 }, '-=0.45')
      .fromTo('.hero .cta-row', { opacity: 0, y: 14 }, { opacity: 1, y: 0, duration: 0.6 }, '-=0.45')
      .fromTo('.hero .cue', { opacity: 0 }, { opacity: 1, duration: 0.5 }, '-=0.25');

    /* ---------- reading-progress hairline under the nav ---------- */
    gsap.fromTo(
      '[data-nav-prog]',
      { scaleX: 0 },
      { scaleX: 1, ease: 'none', scrollTrigger: { start: 0, end: 'max', scrub: 0.3 } }
    );

    /* ---------- generic scroll reveals ---------- */
    gsap.utils.toArray<HTMLElement>('[data-reveal]').forEach((el) => {
      gsap.fromTo(
        el,
        { opacity: 0, y: 26 },
        {
          opacity: 1,
          y: 0,
          duration: 0.9,
          ease: 'power3.out',
          delay: Number(el.dataset.revealDelay ?? 0),
          scrollTrigger: { trigger: el, start: 'top 88%', once: true },
        }
      );
    });

    /* ---------- the signature: ORP alignment, pinned + scrubbed ----------
       The column starts as ordinary left-aligned text; the accent hairline
       draws in, then every word slides until its pivot letter sits on the
       line — the product's whole idea, told by scroll. */
    const col = document.querySelector<HTMLElement>('[data-orp]');
    if (col) {
      const rows = gsap.utils.toArray<HTMLElement>('.orp-row', col);
      const probe = document.createElement('span');
      probe.textContent = '0';
      probe.style.cssText = 'position:absolute;visibility:hidden;white-space:pre;';
      col.appendChild(probe);
      const chPx = probe.getBoundingClientRect().width;
      probe.remove();
      const padOf = (row: HTMLElement) =>
        Number(row.style.getPropertyValue('--pad') || 0) * chPx;

      const mm = gsap.matchMedia();

      mm.add('(min-width: 920px) and (min-height: 720px)', () => {
        const steps = gsap.utils.toArray<HTMLElement>('.how .step');
        gsap.set(steps, { opacity: 0.28 });
        gsap.set('.how-demo', { opacity: 0, y: 18 });
        const pin = gsap.timeline({
          scrollTrigger: {
            trigger: '.how-pin',
            start: 'top top+=64', // clear the sticky nav
            end: '+=160%',
            pin: true,
            scrub: 0.5,
            anticipatePin: 1,
          },
        });
        pin
          .fromTo(
            rows,
            { opacity: 0, x: (_i: number, t: HTMLElement) => -padOf(t) },
            {
              opacity: 1,
              x: (_i: number, t: HTMLElement) => -padOf(t),
              duration: 0.35,
              stagger: 0.05,
            }
          )
          .to(steps[0] ?? {}, { opacity: 1, duration: 0.25 }, '<')
          .fromTo(
            '.orp-line',
            { scaleY: 0 },
            { scaleY: 1, duration: 0.45, ease: 'power2.inOut' },
            '+=0.1'
          )
          .to(steps[1] ?? {}, { opacity: 1, duration: 0.25 }, '<')
          .to(rows, { x: 0, duration: 0.9, stagger: 0.07, ease: 'power2.inOut' }, '+=0.15')
          .to(steps[2] ?? {}, { opacity: 1, duration: 0.3 }, '-=0.5')
          .to('.how-demo', { opacity: 1, y: 0, duration: 0.5 }, '-=0.2');
      });

      mm.add('(max-width: 919px), (max-height: 719px)', () => {
        // compact screens: the column arrives already aligned, the line draws in
        gsap.fromTo(
          rows,
          { opacity: 0, y: 10 },
          {
            opacity: 1,
            y: 0,
            stagger: 0.06,
            duration: 0.5,
            scrollTrigger: { trigger: col, start: 'top 85%', once: true },
          }
        );
        gsap.fromTo(
          '.orp-line',
          { scaleY: 0 },
          {
            scaleY: 1,
            duration: 0.9,
            ease: 'power2.inOut',
            scrollTrigger: { trigger: col, start: 'top 85%', once: true },
          }
        );
      });
    }

    /* ---------- final CTA lines (same mask move as the hero) ---------- */
    if (document.querySelector('.fin-line')) {
      gsap.fromTo(
        '.fin-line',
        { yPercent: 115 },
        {
          yPercent: 0,
          duration: 0.85,
          stagger: 0.12,
          ease: 'power4.out',
          scrollTrigger: { trigger: '.final', start: 'top 72%', once: true },
        }
      );
    }

    /* ---------- anime.js v4: the micro-layer ---------- */

    // count-ups (the HTML ships the final value; motion replays it)
    document.querySelectorAll<HTMLElement>('[data-count]').forEach((el) => {
      const to = parseFloat(el.dataset.count || '0');
      const from = parseFloat(el.dataset.countFrom ?? '0');
      const state = { v: from };
      el.textContent = String(Math.round(from));
      ScrollTrigger.create({
        trigger: el,
        start: 'top 88%',
        once: true,
        onEnter: () =>
          animate(state, {
            v: to,
            duration: 1700,
            ease: 'outExpo',
            onUpdate: () => {
              el.textContent = String(Math.round(state.v));
            },
            onComplete: () => {
              el.textContent = String(to);
            },
          }),
      });
    });

    // staggered feature lists (plans)
    document.querySelectorAll<HTMLElement>('[data-stagger]').forEach((list) => {
      const items = Array.from(list.children) as HTMLElement[];
      gsap.set(items, { opacity: 0 });
      ScrollTrigger.create({
        trigger: list,
        start: 'top 86%',
        once: true,
        onEnter: () =>
          animate(items, {
            opacity: [0, 1],
            x: [-8, 0],
            duration: 480,
            delay: stagger(45),
            ease: 'outQuad',
          }),
      });
    });

    // arrow nudge on every primary CTA
    document.querySelectorAll<HTMLElement>('.btn, .cta').forEach((btn) => {
      const ar = btn.querySelector<HTMLElement>('.ar');
      if (!ar) return;
      btn.addEventListener('mouseenter', () =>
        animate(ar, { x: [0, 7, 0], duration: 460, ease: 'inOutQuad' })
      );
    });

    // the scroll cue bobs forever
    const cueGlyph = document.querySelector<HTMLElement>('.cue-g');
    if (cueGlyph) {
      animate(cueGlyph, {
        y: [0, 6],
        duration: 640,
        alternate: true,
        loop: true,
        ease: 'inOutSine',
      });
    }

    // use-case tags flicker like the reader on hover
    document.querySelectorAll<HTMLElement>('.uc').forEach((card) => {
      const tag = card.querySelector<HTMLElement>('.uc-tag');
      if (!tag) return;
      card.addEventListener('mouseenter', () =>
        animate(tag, { opacity: [1, 0.15, 1, 0.4, 1], duration: 340, ease: 'linear' })
      );
    });

    window.addEventListener('load', () => ScrollTrigger.refresh());
  }
</script>
