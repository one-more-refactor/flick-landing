---
// The ambient field — a monochrome accent dot-matrix behind the whole page
// (Vanta DOTS + three.js). Strictly off the critical path: both libraries are
// dynamically imported after `load`, and only when the visitor allows motion.
// Colors are read live from the brand tokens, so the field re-tints itself
// whenever data-mode / data-theme flips, and the effect is destroyed on
// pagehide and whenever prefers-reduced-motion switches on.
---

<div class="vanta-bg" data-vanta aria-hidden="true"></div>

<script>
  const holder = document.querySelector<HTMLElement>('[data-vanta]');
  const mq = window.matchMedia('(prefers-reduced-motion: reduce)');

  interface Effect {
    destroy: () => void;
  }
  type Factory = (options: Record<string, unknown>) => Effect;

  let effect: Effect | null = null;
  let libs: { THREE: unknown; DOTS: Factory } | null = null;
  let building = false;
  let stopped = false;
  let retint: ReturnType<typeof setTimeout> | undefined;

  const css = (name: string) =>
    getComputedStyle(document.documentElement).getPropertyValue(name).trim();

  /** '#rgb' / '#rrggbb' / 'rgb(...)' → 0xRRGGBB for three.js */
  function hex(name: string): number {
    const v = css(name);
    if (v.startsWith('#')) {
      const h =
        v.length === 4
          ? v.slice(1).split('').map((c) => c + c).join('')
          : v.slice(1, 7);
      const n = parseInt(h, 16);
      if (!Number.isNaN(n)) return n;
    }
    const m = v.match(/rgba?\(([^)]+)\)/);
    if (m) {
      const [r = 0, g = 0, b = 0] = m[1].split(',').map((s) => parseInt(s.trim(), 10));
      return (r << 16) | (g << 8) | b;
    }
    return 0x888888;
  }

  const palette = () => ({
    color: hex('--accent'),
    color2: hex('--dim'),
    backgroundColor: hex('--bg'),
  });

  async function build() {
    if (!holder || effect || building || stopped || mq.matches) return;
    if (window.innerWidth < 760) return; // keep phones cool
    const conn = (navigator as { connection?: { saveData?: boolean } }).connection;
    if (conn?.saveData) return;
    building = true;
    try {
      if (!libs) {
        const three = await import('three');
        // vanta's dist effects capture `window.THREE` at module scope (passing
        // `options.THREE` only reaches the base class), so the global must be
        // set BEFORE the effect module is imported
        const w = window as { THREE?: unknown };
        w.THREE = w.THREE ?? three;
        const dotsMod = await import('vanta/dist/vanta.dots.min');
        const DOTS = (dotsMod.default ?? dotsMod) as Factory;
        libs = { THREE: three, DOTS };
      }
      if (mq.matches || stopped) return; // preference or lifecycle changed while loading
      effect = libs.DOTS({
        el: holder,
        THREE: libs.THREE,
        mouseControls: true,
        touchControls: false,
        gyroControls: false,
        minHeight: 200,
        minWidth: 200,
        scale: 1,
        scaleMobile: 1,
        showLines: false,
        size: 2.4,
        spacing: 28,
        ...palette(),
      });
    } catch {
      // the page is complete without the field — fail silent
    } finally {
      building = false;
    }
  }

  function teardown() {
    if (effect) {
      try {
        effect.destroy();
      } catch {
        /* three teardown is best-effort */
      }
      effect = null;
    }
  }

  // re-tint on theme / mode flips (debounced; rebuild picks up new tokens)
  const themeObserver = new MutationObserver(() => {
    clearTimeout(retint);
    retint = setTimeout(() => {
      if (!effect) return;
      teardown();
      build();
    }, 180);
  });
  themeObserver.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-mode', 'data-theme'],
  });

  // honor a live change of the motion preference
  const onMotionChange = () => (mq.matches ? teardown() : build());
  mq.addEventListener('change', onMotionChange);

  if (!mq.matches) {
    const whenIdle = () => {
      if ('requestIdleCallback' in window) {
        requestIdleCallback(() => build(), { timeout: 2000 });
      } else {
        setTimeout(build, 600);
      }
    };
    if (document.readyState === 'complete') whenIdle();
    else window.addEventListener('load', whenIdle, { once: true });
  }

  function stop() {
    stopped = true;
    clearTimeout(retint);
    themeObserver.disconnect();
    mq.removeEventListener('change', onMotionChange);
    teardown();
  }

  window.addEventListener('pagehide', stop, { once: true });
</script>
