---
// Hosted plans. The law comes first: what's free stays free — Pro funds the
// open project, it doesn't gate the reader. Feature lists stagger in via
// anime.js ([data-stagger]); the self-host door closes the section.
import { APP_URL, REPO } from '../config';
---

<section id="plans" class="plans section">
  <div class="wrap">
    <div class="sec-head" data-reveal>
      <p class="sec-label">Plans</p>
      <h2 class="sec-h2">Free to read. Pro to go deeper.</h2>
      <p class="law"><b>What's free stays free.</b> Pro exists to fund an indie open-source
      project — it is not a paywall, and the reader will never move behind one.</p>
    </div>

    <div class="grid">
      <article class="plan" data-reveal>
        <header class="head">
          <h3>Free</h3>
          <p class="price"><b>€0</b><span> forever</span></p>
        </header>
        <ul data-stagger>
          <li>The whole reader — every speed, every theme</li>
          <li>Web, phone, and the browser extension</li>
          <li>Every import: paste, PDF, EPUB, TXT, Markdown, URLs, Kindle clippings, cloud links</li>
          <li>Share links to anything you read</li>
          <li>15 uploads a week, uncapped storage</li>
          <li>Streaks, goals, stats, your yearly Wrapped, the friends scoreboard</li>
          <li>90 days of reading history</li>
        </ul>
        <a class="btn plan-btn" href={APP_URL}>Start free <span class="ar">→</span></a>
      </article>

      <article class="plan pro" data-reveal data-reveal-delay="0.08">
        <header class="head">
          <h3>Pro <span class="badge">supports the project</span></h3>
          <p class="price"><b>€4</b><span>/month — or €36 a year</span></p>
        </header>
        <ul data-stagger>
          <li>Everything in Free</li>
          <li>Unlimited uploads</li>
          <li>Reading history that never expires</li>
          <li>Deep server-side reading insights <i class="soon">soon</i></li>
          <li>Keeps the servers on and the project moving</li>
        </ul>
        <a class="btn plan-btn" href={APP_URL}>Go Pro <span class="ar">→</span></a>
      </article>
    </div>

    <aside class="selfhost" data-reveal>
      <p>
        <b>Rather run it yourself?</b> flick is AGPL and self-hostable — the same reader on
        your own box, your data on your disk, no account with us at all.
      </p>
      <a class="sh-link" href={REPO} target="_blank" rel="noopener">host it yourself ↗</a>
    </aside>
  </div>
</section>

<style>
  .sec-head { margin-bottom: clamp(32px, 5vh, 48px); }
  .law {
    margin: 18px 0 0;
    max-width: 62ch;
    font-size: 14px;
    line-height: 1.7;
    color: var(--dim);
    border-left: 2px solid var(--accent);
    padding-left: 16px;
  }
  .law b { color: var(--ink); }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
    align-items: stretch;
  }
  .plan {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--line);
    background: var(--panel);
    padding: 28px 26px 26px;
    transition: border-color var(--t-std) var(--ease);
  }
  .plan:hover { border-color: var(--ink); }
  .plan.pro { border-top: 3px solid var(--accent); }

  .head { margin-bottom: 18px; }
  .plan h3 {
    margin: 0 0 10px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .badge {
    font-size: 9px;
    letter-spacing: 0.2em;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 3px 7px;
  }
  .price { margin: 0; display: flex; align-items: baseline; gap: 8px; }
  .price b { font-size: 34px; font-weight: 700; line-height: 1; }
  .price span { font-size: 12px; color: var(--dim); }

  .plan ul {
    list-style: none;
    margin: 0 0 26px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .plan li {
    font-size: 13px;
    line-height: 1.6;
    color: var(--dim);
    padding-left: 18px;
    position: relative;
  }
  .plan li::before {
    content: '+';
    position: absolute;
    left: 0;
    color: var(--accent);
  }
  .soon {
    font-style: normal;
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--dim);
    border: 1px solid var(--line);
    padding: 2px 6px;
    margin-left: 6px;
  }
  .plan-btn { margin-top: auto; align-self: flex-start; }

  .selfhost {
    margin-top: 18px;
    border: 1px dashed var(--line);
    padding: 22px 26px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }
  .selfhost p { margin: 0; font-size: 13px; line-height: 1.7; color: var(--dim); max-width: 58ch; }
  .selfhost b { color: var(--ink); }
  .sh-link {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    white-space: nowrap;
  }
  .sh-link:hover { text-decoration: underline; text-underline-offset: 4px; }

  @media (max-width: 800px) {
    .grid { grid-template-columns: minmax(0, 1fr); }
  }
</style>
