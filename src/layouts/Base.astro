---
import '../styles/tokens.css';
import '../styles/landing.css';
import { SITE } from '../config';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'flick — read it in a flick',
  description = 'flick is a speed reader: one word at a time on the pivot letter, so your eyes never move and you read two to three times faster. Open source and self-hostable.',
  image = '/og.png',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, SITE).href;
const ogImage = new URL(image, SITE).href;

// Keywords are the words people actually type when hunting for a tool like
// this — including the platforms they search from (e.g. Reddit). This tag is
// not rendered to visitors; it's a hint for crawlers and AI indexers. The
// fuller, plain-language version lives in /llms.txt.
const keywords = [
  'speed reading', 'speed reader', 'RSVP reader', 'read faster',
  'read 2-3x faster', 'rapid serial visual presentation', 'ORP', 'pivot letter',
  'Spritz alternative', 'Spreeder alternative', 'Reedy alternative',
  'Outread alternative', 'open source speed reader', 'self-hosted speed reader',
  'self-hostable reading app', 'privacy speed reader', 'no account reading app',
  'EPUB speed reader', 'PDF speed reader', 'Kindle clippings reader',
  'speed reading reddit', 'r/speedreading', 'r/selfhosted', 'reddit speed reader',
  'AGPL reading app', 'flick reader', 'myflick',
].join(', ');

// Structured data so Google/Bing understand this is a free web app, and so it
// can qualify for rich results. https://schema.org/SoftwareApplication
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${SITE}/#website`,
      url: `${SITE}/`,
      name: 'flick',
      description,
      inLanguage: ['en', 'de', 'es'],
    },
    {
      '@type': 'SoftwareApplication',
      '@id': `${SITE}/#app`,
      name: 'flick',
      applicationCategory: 'UtilitiesApplication',
      operatingSystem: 'Web, Linux, macOS, Windows',
      url: `${SITE}/`,
      downloadUrl: `${SITE}/install.sh`,
      description,
      license: 'https://www.gnu.org/licenses/agpl-3.0.en.html',
      isAccessibleForFree: true,
      keywords,
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'EUR',
        description: 'Free to read; self-host everything with no limits.',
      },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="one more refactor" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <!-- a plain-language summary written for AI crawlers: /llms.txt -->
    <link rel="alternate" type="text/plain" title="llms.txt" href="/llms.txt" />
    <meta name="theme-color" content="#0c0a08" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f5f2ea" media="(prefers-color-scheme: light)" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="flick" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />

    <!-- set the theme before first paint (shares flick.mode / flick.theme with
         the app on the same origin, so a returning reader keeps their look) -->
    <script is:inline>
      (function () {
        try {
          var m = localStorage.getItem('flick.mode');
          var t = localStorage.getItem('flick.theme');
          var mode = m === 'light' || m === 'dark'
            ? m
            : window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          var themes = ['paper', 'signal', 'sage', 'tide', 'dusk', 'noir'];
          var theme = themes.indexOf(t) >= 0 ? t : 'paper';
          var r = document.documentElement;
          r.setAttribute('data-mode', mode);
          r.setAttribute('data-theme', theme);
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <Fragment set:html={`<!--
      for whoever reads the source. hi.

       #####  #      #  ####  #    #
       #      #      # #    # #   #      read it in a flick.
       #####  #      # #      ####       one word at a time, on the pivot.
       #      #      # #    # #   #
       #      ###### #  ####  #    #      the whole thing is open. AGPL-3.0,
                                          self-host in one line:
       #    curl -fsSL https://myflick.app/install.sh | sh

       like taking things apart? the source is the product:
       https://github.com/one-more-refactor    ·    #madeintheopen
    -->`} />
    <slot />
    <script is:inline>
      (function () {
        try {
          var big = 'font:700 13px/1.4 ui-monospace,Menlo,monospace;color:#d8342b';
          var dim = 'font:12px/1.5 ui-monospace,Menlo,monospace;color:#8a8a8a';
          console.log(
            '%cflick_%c\n\nread it in a flick — one word at a time, on the pivot letter.\n' +
              'the source is the product: https://github.com/one-more-refactor\n' +
              'self-host in one line:  curl -fsSL https://myflick.app/install.sh | sh\n\n' +
              'poking around the internals? you might like building it. #madeintheopen',
            big,
            dim
          );
        } catch (e) {}
      })();
    </script>
  </body>
</html>
