---
// Shared frame for the legal pages (/impressum, /datenschutz): the brand
// hairline header, a narrow document column, and the site footer. Same tokens
// as everything else — monospace, square, one accent, no decoration.
import Base from './Base.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  heading: string;
  updated?: string;
}

const { title, description, heading, updated } = Astro.props;
---

<Base title={title} description={description}>
  <div class="site">
    <header class="top">
      <div class="wrap top-row">
        <a class="mark" href="/">FLICK<span class="cur">_</span></a>
        <nav class="nav" aria-label="Legal">
          <a class="link" href="/impressum/">Impressum</a>
          <a class="link" href="/datenschutz/">Datenschutz</a>
        </nav>
      </div>
    </header>

    <main class="doc-main">
      <article class="wrap doc">
        <h1>{heading}</h1>
        {updated && <p class="updated">Stand: {updated}</p>}
        <slot />
      </article>
    </main>

    <Footer />
  </div>
</Base>

<style>
  .top { border-bottom: 1px solid var(--line); background: var(--bg); }
  .top-row { display: flex; align-items: center; justify-content: space-between; height: 64px; }
  .mark { font-size: 15px; font-weight: 700; letter-spacing: 0.22em; }
  .cur { color: var(--accent); }
  .nav { display: flex; gap: 20px; }
  .link {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--dim);
    transition: color var(--t-std) var(--ease);
  }
  .link:hover { color: var(--ink); }

  .doc-main { padding: 48px 0 72px; }
  .doc { max-width: 720px; }
  .doc h1 {
    font-size: 22px;
    letter-spacing: 0.06em;
    margin: 0 0 6px;
  }
  .updated { font-size: 11px; color: var(--dim); letter-spacing: 0.08em; margin: 0 0 34px; }

  .doc :global(h2) {
    font-size: 13px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 40px 0 10px;
    padding-top: 18px;
    border-top: 1px solid var(--line);
  }
  .doc :global(h3) {
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--dim);
    margin: 22px 0 6px;
  }
  .doc :global(p),
  .doc :global(li) { font-size: 13px; line-height: 1.7; color: var(--ink); }
  .doc :global(p) { margin: 10px 0; }
  .doc :global(ul) { margin: 10px 0; padding-left: 20px; }
  .doc :global(li) { margin: 5px 0; }
  .doc :global(a) { color: var(--accent); text-decoration: underline; text-underline-offset: 2px; }
  .doc :global(strong) { font-weight: 700; }
  .doc :global(.quiet) { color: var(--dim); font-size: 12px; }
  .doc :global(address) { font-style: normal; }

  /* operator details still to be filled in by the operator — visually loud on
     purpose so a placeholder can never quietly pass as a real Impressum */
  .doc :global(.fill) {
    background: none;
    color: var(--accent);
    border: 1px dashed var(--accent);
    padding: 0 4px;
    white-space: nowrap;
  }
</style>
